# Supabase direct connection (Project Settings → Database → Connection string).
DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# Supabase Storage S3 (Project Settings → Storage → S3 connection).
# Create the bucket in Storage before uploading (default name: attachments).
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_ENDPOINT=https://xxxxxxxxxxxxxxxxxxxx.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-west-1
SUPABASE_STORAGE_BUCKET=attachments
