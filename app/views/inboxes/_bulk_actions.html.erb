<div class="mb-3 flex items-center justify-between rounded-lg border border-gray-200 bg-white px-4 py-2.5 shadow-sm"
     data-controller="bulk-actions">
  <div class="flex items-center gap-x-3">
    <input type="checkbox" id="select-all"
           class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500"
           data-action="change->bulk-actions#selectAll"
           data-bulk-actions-target="selectAll">
    <label for="select-all" class="text-sm text-gray-700">
      <span class="font-medium"><%= count %></span> items
    </label>
  </div>

  <div class="flex items-center gap-x-2">
    <button type="button"
            class="inline-flex items-center gap-x-1.5 rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-gray-600 shadow-sm hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed transition-colors duration-150"
            disabled
            data-bulk-actions-target="actionButton">
      <svg class="-ml-0.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
      </svg>
      Process
    </button>
    <button type="button"
            class="inline-flex items-center gap-x-1.5 rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-gray-600 shadow-sm hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed transition-colors duration-150"
            disabled
            data-bulk-actions-target="actionButton">
      <svg class="-ml-0.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M2 3.75A.75.75 0 0 1 2.75 3h14.5a.75.75 0 0 1 0 1.5h-1.549l-.02.005a3.75 3.75 0 0 0-2.952 2.951l-.004.02-.003.021-.006.055a1.25 1.25 0 0 0 0 .146l.006.055.003.02.004.022a3.75 3.75 0 0 0 2.952 2.952l.02.004.021.003.055.006.055-.006.02-.003.022-.004A3.75 3.75 0 0 0 17.7 7.75h.55a.75.75 0 0 1 0 1.5h-.55a5.25 5.25 0 0 1-4.824 4.824v1.676h.75a.75.75 0 0 1 0 1.5h-3a.75.75 0 0 1 0-1.5h.75v-1.676A5.25 5.25 0 0 1 5.55 9.25H5a.75.75 0 0 1 0-1.5h.55A5.25 5.25 0 0 1 10 3.276V3h-.25a.75.75 0 0 1-.75-.75V.75A.75.75 0 0 1 10 0h.5a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-.75.75H10v.726A5.25 5.25 0 0 1 14.45 7.75h.55Z" clip-rule="evenodd" />
      </svg>
      Archive
    </button>
    <button type="button"
            class="inline-flex items-center gap-x-1.5 rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-gray-600 shadow-sm hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed transition-colors duration-150"
            disabled
            data-bulk-actions-target="actionButton">
      <svg class="-ml-0.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path d="M5.5 3A2.5 2.5 0 0 0 3 5.5v2.879a2.5 2.5 0 0 0 .732 1.767l6.5 6.5a2.5 2.5 0 0 0 3.536 0l2.878-2.878a2.5 2.5 0 0 0 0-3.536l-6.5-6.5A2.5 2.5 0 0 0 8.38 3H5.5ZM6 7a1 1 0 1 1 0-2 1 1 0 0 1 0 2Z" />
      </svg>
      Tag
    </button>
    <button type="button"
            class="inline-flex items-center gap-x-1.5 rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-red-600 shadow-sm hover:bg-red-50 disabled:opacity-40 disabled:cursor-not-allowed transition-colors duration-150"
            disabled
            data-bulk-actions-target="actionButton">
      <svg class="-ml-0.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 0 0 6 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 1 0 .23 1.482l.149-.022.841 10.518A2.75 2.75 0 0 0 7.596 19h4.807a2.75 2.75 0 0 0 2.742-2.53l.841-10.52.149.023a.75.75 0 0 0 .23-1.482A41.03 41.03 0 0 0 14 4.193V3.75A2.75 2.75 0 0 0 11.25 1h-2.5ZM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4ZM8.58 7.72a.75.75 0 0 0-1.5.06l.3 7.5a.75.75 0 1 0 1.5-.06l-.3-7.5Zm4.34.06a.75.75 0 1 0-1.5-.06l-.3 7.5a.75.75 0 1 0 1.5.06l.3-7.5Z" clip-rule="evenodd" />
      </svg>
      Delete
    </button>
  </div>
</div>
