<%= form_with(model: inbox, html: { multipart: true }, class: "space-y-6") do |f| %>
  <% if inbox.errors.any? %>
    <div class="rounded-md bg-red-50 border border-red-200 p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-red-400 shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16ZM8.28 7.22a.75.75 0 0 0-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 1 0 1.06 1.06L10 11.06l1.72 1.72a.75.75 0 1 0 1.06-1.06L11.06 10l1.72-1.72a.75.75 0 0 0-1.06-1.06L10 8.94 8.28 7.22Z" clip-rule="evenodd" />
        </svg>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(inbox.errors.count, 'error') %> prevented this inbox item from being saved:
          </h3>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-red-700">
            <% inbox.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <%# Basic fields %>
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name,
            class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500",
            placeholder: "e.g. Support queue" %>
    </div>

    <div>
      <%= f.label :source, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :source,
            class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500",
            placeholder: "e.g. email, webhook, api" %>
    </div>
  </div>

  <div>
    <%= f.label :tag_id, "Tag", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :tag_id,
          options_from_collection_for_select(@tags, :id, :name),
          { include_blank: '— No tag —' },
          class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :summary, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :summary, rows: 3,
          class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500",
          placeholder: "A short description of this inbox entry" %>
  </div>

  <%# JSON fields %>
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div>
      <%= f.label :payload_text, "Payload (JSON)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :payload_text, rows: 10,
            class: "block w-full rounded-md border border-gray-300 px-3 py-2 font-mono text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500",
            placeholder: '{\n  "key": "value"\n}',
            spellcheck: false %>
      <p class="mt-1 text-xs text-gray-500">Must be valid JSON. Defaults to <code class="font-mono">{}</code>.</p>
    </div>

    <div>
      <%= f.label :metadata_text, "Metadata (JSON)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :metadata_text, rows: 10,
            class: "block w-full rounded-md border border-gray-300 px-3 py-2 font-mono text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500",
            placeholder: '{\n  "key": "value"\n}',
            spellcheck: false %>
      <p class="mt-1 text-xs text-gray-500">Must be valid JSON. Defaults to <code class="font-mono">{}</code>.</p>
    </div>
  </div>

  <%# Attachments %>
  <div>
    <p class="block text-sm font-medium text-gray-700 mb-2">Attachments</p>

    <% if inbox.attachments.attached? %>
      <ul class="mb-4 space-y-2 rounded-md border border-gray-200 divide-y divide-gray-100">
        <% inbox.attachments.each do |attachment| %>
          <li class="flex items-center gap-x-3 px-4 py-3">
            <%= check_box_tag 'inbox[purge_attachment_signed_ids][]', attachment.blob.signed_id, false,
                  id: "purge_attachment_#{attachment.id}",
                  class: "h-4 w-4 rounded border-gray-300 text-red-600 focus:ring-red-500" %>
            <%= label_tag "purge_attachment_#{attachment.id}", class: "flex-1 min-w-0 cursor-pointer" do %>
              <span class="text-sm font-medium text-gray-900"><%= attachment.filename %></span>
              <span class="text-xs text-gray-500 ml-2"><%= number_to_human_size(attachment.byte_size) %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
      <p class="mb-4 text-xs text-gray-500">Checked files will be permanently removed on save.</p>
    <% else %>
      <div class="mb-4 rounded-md border border-dashed border-gray-300 bg-gray-50 px-4 py-6 text-center">
        <p class="text-sm text-gray-500">No attachments</p>
      </div>
    <% end %>

    <div>
      <%= f.label :attachments, "Add attachments", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.file_field :attachments, multiple: true, include_hidden: false,
            class: "block w-full text-sm text-gray-900 file:mr-4 file:rounded-md file:border-0 file:bg-gray-100 file:px-3 file:py-2 file:text-sm file:font-medium file:text-gray-700 hover:file:bg-gray-200" %>
      <p class="mt-1 text-xs text-gray-500">Select one or more files to add. Hold Cmd or Ctrl to select multiple files.</p>
    </div>
  </div>

  <div class="flex items-center gap-x-3 pt-2">
    <%= f.submit inbox.persisted? ? 'Update Inbox Item' : 'Create Inbox Item',
          data: { keyboard_shortcuts_target: "trigger", keyboard_shortcuts_key: "Enter" },
          class: "inline-flex items-center gap-x-1.5 justify-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 transition-colors duration-150 cursor-pointer" %>
    <%= link_to 'Cancel', inbox.persisted? ? inbox : inboxes_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900 transition-colors duration-150" %>
    <span class="ml-auto text-xs text-gray-400"><kbd class="rounded border border-gray-200 bg-gray-100 px-1 py-0.5 font-mono text-xs text-gray-400">Esc</kbd> to exit field, then <kbd class="rounded border border-gray-200 bg-gray-100 px-1 py-0.5 font-mono text-xs text-gray-400">↵</kbd> to submit</span>
  </div>
<% end %>
