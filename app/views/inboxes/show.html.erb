<div data-controller="keyboard-shortcuts">

<%# Help overlay %>
<div data-keyboard-shortcuts-target="help"
     data-action="click->keyboard-shortcuts#closeHelp"
     aria-hidden="true"
     class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="w-full max-w-sm rounded-xl border border-gray-200 bg-white shadow-2xl">
    <div class="flex items-center justify-between border-b border-gray-100 px-5 py-4">
      <h2 class="text-sm font-semibold text-gray-900">Keyboard Shortcuts</h2>
      <kbd class="inline-flex items-center rounded border border-gray-200 bg-gray-100 px-1.5 py-0.5 font-mono text-xs text-gray-600">?</kbd>
    </div>

    <div class="px-5 pt-3 pb-1">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-400">Item view</p>
    </div>
    <ul class="divide-y divide-gray-100 px-5 pb-2">
      <li class="flex items-center justify-between py-2.5">
        <span class="text-sm text-gray-700">Edit</span>
        <kbd class="inline-flex items-center rounded border border-gray-200 bg-gray-100 px-1.5 py-0.5 font-mono text-xs text-gray-600">e</kbd>
      </li>
      <% unless @inbox.processed? || @inbox.archived? %>
      <li class="flex items-center justify-between py-2.5">
        <span class="text-sm text-gray-700">Process</span>
        <kbd class="inline-flex items-center rounded border border-gray-200 bg-gray-100 px-1.5 py-0.5 font-mono text-xs text-gray-600">p</kbd>
      </li>
      <% end %>
      <li class="flex items-center justify-between py-2.5">
        <span class="text-sm text-gray-700">Tag</span>
        <kbd class="inline-flex items-center rounded border border-gray-200 bg-gray-100 px-1.5 py-0.5 font-mono text-xs text-gray-600">t</kbd>
      </li>
      <li class="flex items-center justify-between py-2.5">
        <span class="text-sm text-gray-700"><%= @inbox.archived? ? 'Unarchive' : 'Archive' %></span>
        <kbd class="inline-flex items-center rounded border border-gray-200 bg-gray-100 px-1.5 py-0.5 font-mono text-xs text-gray-600">a</kbd>
      </li>
      <li class="flex items-center justify-between py-2.5">
        <span class="text-sm text-gray-700">Delete</span>
        <kbd class="inline-flex items-center rounded border border-gray-200 bg-gray-100 px-1.5 py-0.5 font-mono text-xs text-gray-600">d</kbd>
      </li>
      <li class="flex items-center justify-between py-2.5">
        <span class="text-sm text-gray-700">Back to Inbox</span>
        <kbd class="inline-flex items-center rounded border border-gray-200 bg-gray-100 px-1.5 py-0.5 font-mono text-xs text-gray-600">u</kbd>
      </li>
    </ul>

    <div class="border-t border-gray-100 px-5 pt-3 pb-3 flex items-center justify-between">
      <p class="text-xs text-gray-400">Disabled while typing in a field.</p>
      <div class="flex items-center gap-x-1 text-xs text-gray-400">
        <span>Toggle help</span>
        <kbd class="inline-flex items-center rounded border border-gray-200 bg-gray-100 px-1.5 py-0.5 font-mono text-xs text-gray-600">?</kbd>
      </div>
    </div>
  </div>
</div>

<div class="mb-8 flex items-center justify-between">
  <div class="flex items-center gap-x-3">
    <%= link_to inboxes_path,
          title: "Back to Inbox (u)",
          data: { keyboard_shortcuts_target: "trigger", keyboard_shortcuts_key: "u" },
          class: "inline-flex items-center gap-x-1.5 text-sm text-gray-500 hover:text-gray-700 transition-colors duration-150" do %>
      &larr; Inbox
      <kbd class="rounded border border-gray-200 bg-gray-100 px-1 py-0.5 font-mono text-xs font-normal text-gray-400">u</kbd>
    <% end %>
    <span class="text-gray-300">/</span>
    <h1 class="text-2xl font-semibold text-gray-900"><%= @inbox.name.presence || '(untitled)' %></h1>
  </div>
  <div class="flex items-center gap-x-2">
    <% unless @inbox.processed? || @inbox.archived? %>
      <%= link_to process_inbox_path(@inbox),
            title: "Process (p)",
            data: { turbo_frame: 'modal', keyboard_shortcuts_target: "trigger", keyboard_shortcuts_key: "p" },
            class: "inline-flex items-center gap-x-1.5 rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-colors duration-150" do %>
        Process
        <kbd class="rounded border border-gray-200 bg-gray-100 px-1 py-0.5 font-mono text-xs font-normal text-gray-500">p</kbd>
      <% end %>
    <% end %>

    <%= link_to tag_inbox_path(@inbox),
          title: "Tag (t)",
          data: { turbo_frame: 'modal', keyboard_shortcuts_target: "trigger", keyboard_shortcuts_key: "t" },
          class: "inline-flex items-center gap-x-1.5 rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-colors duration-150" do %>
      Tag
      <kbd class="rounded border border-gray-200 bg-gray-100 px-1 py-0.5 font-mono text-xs font-normal text-gray-500">t</kbd>
    <% end %>

    <% if @inbox.archived? %>
      <%= button_to unarchive_inbox_path(@inbox), method: :patch,
            title: "Unarchive (a)",
            form: { data: { turbo_confirm: "Restore \"#{@inbox.name}\" to inbox?" } },
            data: { keyboard_shortcuts_target: "trigger", keyboard_shortcuts_key: "a" },
            class: "inline-flex items-center gap-x-1.5 rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-colors duration-150 cursor-pointer" do %>
        Unarchive
        <kbd class="rounded border border-gray-200 bg-gray-100 px-1 py-0.5 font-mono text-xs font-normal text-gray-500">a</kbd>
      <% end %>
    <% else %>
      <%= button_to archive_inbox_path(@inbox), method: :patch,
            title: "Archive (a)",
            form: { data: { turbo_confirm: "Archive \"#{@inbox.name}\"? This will move it to the archive." } },
            data: { keyboard_shortcuts_target: "trigger", keyboard_shortcuts_key: "a" },
            class: "inline-flex items-center gap-x-1.5 rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-colors duration-150 cursor-pointer" do %>
        Archive
        <kbd class="rounded border border-gray-200 bg-gray-100 px-1 py-0.5 font-mono text-xs font-normal text-gray-500">a</kbd>
      <% end %>
    <% end %>

    <div class="w-px h-6 bg-gray-200"></div>

    <%= link_to edit_inbox_path(@inbox),
          title: "Edit (e)",
          data: { keyboard_shortcuts_target: "trigger", keyboard_shortcuts_key: "e" },
          class: "inline-flex items-center gap-x-1.5 rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-colors duration-150" do %>
      Edit
      <kbd class="rounded border border-gray-200 bg-gray-100 px-1 py-0.5 font-mono text-xs font-normal text-gray-500">e</kbd>
    <% end %>

    <%= button_to @inbox, method: :delete,
          title: "Delete (d)",
          form: { data: { turbo_confirm: "Delete \"#{@inbox.name}\"? This cannot be undone." } },
          data: { keyboard_shortcuts_target: "trigger", keyboard_shortcuts_key: "d" },
          class: "inline-flex items-center gap-x-1.5 rounded-md bg-red-50 px-3 py-2 text-sm font-semibold text-red-700 shadow-sm ring-1 ring-inset ring-red-200 hover:bg-red-100 transition-colors duration-150 cursor-pointer" do %>
      Delete
      <kbd class="rounded border border-gray-200 bg-gray-100 px-1 py-0.5 font-mono text-xs font-normal text-gray-500">d</kbd>
    <% end %>

    <button title="Keyboard shortcuts (?)"
            data-action="click->keyboard-shortcuts#toggleHelp"
            class="inline-flex items-center justify-center rounded-full w-8 h-8 bg-white text-gray-500 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-colors duration-150 font-semibold text-sm">
      ?
    </button>
  </div>
</div>

<div class="space-y-6">
  <%# Basic info card %>
  <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gray-50 px-6 py-3">
      <h2 class="text-sm font-semibold text-gray-700">Details</h2>
    </div>
    <dl class="divide-y divide-gray-100">
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Name</dt>
        <dd class="col-span-2 text-sm text-gray-900"><%= @inbox.name.presence || '—' %></dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Source</dt>
        <dd class="col-span-2 text-sm text-gray-900">
          <% if @inbox.source.present? %>
            <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-700"><%= @inbox.source %></span>
          <% else %>
            <span class="text-gray-400">—</span>
          <% end %>
        </dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Tag</dt>
        <dd class="col-span-2 text-sm text-gray-900">
          <% if @inbox.tag %>
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= @inbox.tag.badge_classes %>"><%= @inbox.tag.name %></span>
          <% else %>
            <span class="text-gray-400">—</span>
          <% end %>
        </dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Summary</dt>
        <dd class="col-span-2 text-sm text-gray-900"><%= @inbox.summary.presence || '—' %></dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Created</dt>
        <dd class="col-span-2 text-sm text-gray-900"><%= @inbox.created_at.strftime('%B %d, %Y at %H:%M UTC') %></dd>
      </div>
      <div class="grid grid-cols-3 gap-4 px-6 py-4">
        <dt class="text-sm font-medium text-gray-500">Updated</dt>
        <dd class="col-span-2 text-sm text-gray-900"><%= @inbox.updated_at.strftime('%B %d, %Y at %H:%M UTC') %></dd>
      </div>
    </dl>
  </div>

  <%# JSON fields side by side %>
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
      <div class="border-b border-gray-100 bg-gray-50 px-6 py-3">
        <h2 class="text-sm font-semibold text-gray-700">Payload</h2>
      </div>
      <div class="p-4">
        <pre class="overflow-auto rounded-md bg-gray-50 p-4 font-mono text-xs text-gray-800 leading-relaxed max-h-80"><%= JSON.pretty_generate(@inbox.payload || {}) %></pre>
      </div>
    </div>

    <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
      <div class="border-b border-gray-100 bg-gray-50 px-6 py-3">
        <h2 class="text-sm font-semibold text-gray-700">Metadata</h2>
      </div>
      <div class="p-4">
        <pre class="overflow-auto rounded-md bg-gray-50 p-4 font-mono text-xs text-gray-800 leading-relaxed max-h-80"><%= JSON.pretty_generate(@inbox.metadata || {}) %></pre>
      </div>
    </div>
  </div>

  <%# Attachments %>
  <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-100 bg-gray-50 px-6 py-3">
      <h2 class="text-sm font-semibold text-gray-700">Attachments</h2>
    </div>
    <div class="px-6 py-4 space-y-4">
      <% if @inbox.attachments.attached? %>
        <ul class="divide-y divide-gray-100 rounded-md border border-gray-200">
          <% @inbox.attachments.each do |attachment| %>
            <li class="flex items-center justify-between gap-x-4 px-4 py-3">
              <div class="flex items-center gap-x-3 min-w-0">
                <svg class="h-5 w-5 shrink-0 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m18.375 12.739-7.693 7.693a4.5 4.5 0 0 1-6.364-6.364l10.94-10.94A3 3 0 1 1 19.5 7.372L8.552 18.32m.009-.01-.01.01m5.699-9.941-7.81 7.81a1.5 1.5 0 0 0 2.112 2.13" />
                </svg>
                <div class="min-w-0">
                  <%= link_to attachment.filename,
                        rails_blob_path(attachment, disposition: 'attachment'),
                        class: "text-sm font-medium text-indigo-600 hover:text-indigo-900 truncate block" %>
                  <p class="text-xs text-gray-500"><%= number_to_human_size(attachment.byte_size) %></p>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-gray-500">No attachments</p>
      <% end %>
    </div>
  </div>
</div>

<turbo-frame id="modal"></turbo-frame>

</div><%# end keyboard-shortcuts %>
