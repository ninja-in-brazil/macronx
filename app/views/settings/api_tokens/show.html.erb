<div class="mb-8">
  <h1 class="text-2xl font-semibold text-gray-900">API Token</h1>
  <p class="mt-1 text-sm text-gray-500">Use this token to authenticate requests to the Macron X API.</p>
</div>

<div class="max-w-2xl space-y-6">
  <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="text-sm font-medium text-gray-900 mb-1">Your API token</h2>
    <p class="text-xs text-gray-500 mb-4">Include this token in the <code class="rounded bg-gray-100 px-1 py-0.5 font-mono text-xs">Authorization: Bearer &lt;token&gt;</code> header of every API request.</p>

    <% if current_user.api_token.present? %>
      <div data-controller="api-token" class="space-y-3">
        <div class="flex items-center gap-x-2">
          <input
            data-api-token-target="input"
            type="password"
            value="<%= current_user.api_token %>"
            readonly
            class="block w-full rounded-lg border border-gray-300 bg-gray-50 px-3 py-2 font-mono text-sm text-gray-900 focus:outline-none"
          />
          <button
            data-api-token-target="revealBtn"
            data-action="click->api-token#toggle"
            type="button"
            class="shrink-0 rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors duration-150 cursor-pointer"
          >Reveal</button>
          <button
            data-api-token-target="copyBtn"
            data-action="click->api-token#copy"
            type="button"
            class="shrink-0 rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors duration-150 cursor-pointer"
          >Copy</button>
        </div>
      </div>
    <% else %>
      <p class="text-sm text-gray-500 italic">No token generated yet. Click below to create one.</p>
    <% end %>
  </div>

  <div class="rounded-lg border border-amber-200 bg-amber-50 p-6">
    <h3 class="text-sm font-medium text-amber-900 mb-1">
      <%= current_user.api_token.present? ? 'Regenerate token' : 'Generate token' %>
    </h3>
    <p class="text-xs text-amber-700 mb-4">
      <%= current_user.api_token.present? ? 'Regenerating will immediately invalidate your current token. Any integrations using it will stop working until updated.' : 'Generate a new token to start making API requests.' %>
    </p>
    <%= button_to settings_api_token_path,
          method: :patch,
          data: current_user.api_token.present? ? { turbo_confirm: 'Regenerate your API token? Your current token will stop working immediately.' } : {},
          class: "rounded-lg px-4 py-2 text-sm font-semibold text-white transition-colors duration-150 cursor-pointer #{current_user.api_token.present? ? 'bg-amber-600 hover:bg-amber-500' : 'bg-indigo-600 hover:bg-indigo-500'}" do %>
      <%= current_user.api_token.present? ? 'Regenerate token' : 'Generate token' %>
    <% end %>
  </div>
</div>
