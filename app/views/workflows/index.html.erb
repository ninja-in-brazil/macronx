<div class="mb-6 flex items-start justify-between">
  <div>
    <h1 class="text-2xl font-semibold text-gray-900">Workflows</h1>
    <p class="mt-1 text-sm text-gray-500">Manage workflows for processing inbox items</p>
  </div>
  <%= link_to new_workflow_path, class: "inline-flex items-center gap-x-1.5 rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-700 transition-colors duration-150" do %>
    <svg class="-ml-0.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
      <path d="M10.75 4.75a.75.75 0 0 0-1.5 0v4.5h-4.5a.75.75 0 0 0 0 1.5h4.5v4.5a.75.75 0 0 0 1.5 0v-4.5h4.5a.75.75 0 0 0 0-1.5h-4.5v-4.5Z" />
    </svg>
    New Workflow
  <% end %>
</div>

<% if @workflows.any? %>
  <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Name</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Inbox Items</th>
          <th scope="col" class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Created</th>
          <th scope="col" class="relative px-6 py-3"><span class="sr-only">Actions</span></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100 bg-white">
        <% @workflows.each do |workflow| %>
          <tr class="hover:bg-gray-50 transition-colors duration-100">
            <td class="px-6 py-4 text-sm font-medium text-gray-900">
              <%= link_to workflow.name, workflow, class: "hover:text-indigo-600 transition-colors duration-150" %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500">
              <span class="inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-medium text-indigo-700">
                <%= workflow.inboxes.count %>
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-gray-500 whitespace-nowrap"><%= workflow.created_at.strftime('%b %d, %Y') %></td>
            <td class="px-6 py-4 text-right text-sm font-medium whitespace-nowrap">
              <div class="flex items-center justify-end gap-x-3">
                <%= link_to 'Edit', edit_workflow_path(workflow), class: "text-gray-600 hover:text-gray-900 transition-colors duration-150" %>
                <%= button_to 'Delete', workflow, method: :delete,
                      data: { turbo_confirm: "Delete \"#{workflow.name}\"? This cannot be undone." },
                      class: "text-red-600 hover:text-red-900 transition-colors duration-150 bg-transparent border-0 p-0 cursor-pointer font-medium" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="flex flex-col items-center justify-center rounded-lg border-2 border-dashed border-gray-300 py-16 text-center">
    <svg class="mx-auto h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z" />
    </svg>
    <h3 class="mt-4 text-sm font-semibold text-gray-900">No workflows</h3>
    <p class="mt-1 text-sm text-gray-500">Create a workflow to start processing inbox items.</p>
    <%= link_to 'New Workflow', new_workflow_path, class: "mt-6 inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition-colors duration-150" %>
  </div>
<% end %>
